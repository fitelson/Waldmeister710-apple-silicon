# compiler setup
CC = gcc
CCC = g++
CF += -pipe -MMD
DEPENDFLAGS = -MM
OPTFLAGS=-O3
ifeq "$(DIR)" "std"
CF+= -Wall -Winline -W -Wmissing-prototypes # -Wstrict-prototypes -Wwrite-strings
CF+= -ggdb
# Alles was GCC/ANSI/POSIX zu bieten hat:
# -D_POSIX_SOURCE -ansi -pedantic -Wall -Wwrite-strings -Wpointer-arith 
# -Wcast-qual  -Wcast-align -Wtraditional -Wstrict-prototypes 
# -Wmissing-prototypes -Wnested-externs -Winline -Wshadow
endif

ifeq "$(DIR)" "cce"
CF += -ggdb #-Wall -W
endif

ifeq "$(DIR)" "prof"
CF+= $(OPTFLAGS) -pg  #-finline-limit=12500 #-fno-strict-aliasing
endif
ifeq "$(DIR)" "fast"
CF+=  $(OPTFLAGS) -fomit-frame-pointer
endif
ifeq "$(DIR)" "power"
CF+= $(OPTFLAGS) -fomit-frame-pointer -Wall -W
endif
ifeq "$(DIR)" "comp"
CF+= $(OPTFLAGS) -fomit-frame-pointer -Wall -W
endif


# OS specific setup
CF += -D$(ARCH)
DEPENDFLAGS+=-D$(ARCH)
ifeq "$(ARCH)" "LINUX"
CF+= -W
CF:=$(filter-out -pedantic, $(CF))
CF:=$(filter-out -ansi, $(CF))
endif

ifeq "$(ARCH)" "DARWIN"
# macOS / Apple Silicon support
CF+= -W
CF:=$(filter-out -pedantic, $(CF))
CF:=$(filter-out -ansi, $(CF))
# Clang doesn't support some GCC-specific flags
CF:=$(filter-out -ggdb, $(CF))
CF+= -g
# Silence some warnings that are noisy in this older codebase
CF+= -Wno-deprecated-non-prototype -Wno-implicit-function-declaration
CF+= -Wno-int-conversion -Wno-format
endif

ifeq "$(ARCH)" "SUNOS5"
CF+=-D_POSIX_PTHREAD_SEMANTICS
endif

# Compiler/OS specific setup
ifeq "$(ARCH).$(DIR)" "LINUX.prof"
ifneq "$(DO_OMEGA)" "1"
LIBS:=$(filter-out -lm, $(LIBS)) #auskommentieruen fuer omega (?)
LIBS+= -profile -lm_p            #auskommentieruen fuer omega (?)
endif
CFLAGS+= -profile
endif

# macOS profiling setup (different from Linux)
ifeq "$(ARCH).$(DIR)" "DARWIN.prof"
# Use -pg for gprof-style profiling on macOS (though limited on Apple Silicon)
CFLAGS+= -pg
endif

# we are done, CF contains now all Flags that we need
CFLAGS=$(CF)

