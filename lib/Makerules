	indent -i2 -nlp -nfc1 -nce -ncdb -npsl -sob -di0 -d0 -nfc1 -l118 $@
	$(CC) $(CPPFLAGS) $(CFLAGS) -xc -o $*.o -c $*.i


%.s: %.c
	$(CC) $(CPPFLAGS) $(CFLAGS) -S -fverbose-asm -o $@ -c $<
	$(CC) -o $*.o -c $*.s


# Rule to generate PCLprogs
$(TOPDIR)/bin/%: %.c
