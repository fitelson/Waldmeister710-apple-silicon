## Rules for generation of include/compile.h
define make-version
@if [ ! -f .version ]; then \
	echo 1 > .version; \
else \
	expr 0`cat .version` + 1 > .version; \
fi
@if [ -f .name ]; then \
  echo \#define BUILD_VERSION \"\#`cat .version`-`cat .name` \"; \
else \
  echo \#define BUILD_VERSION \"\#`cat .version`\";  \
fi >> .ver
@echo \#define WM_COMPILE_DATE \"`date `\" >> .ver
@echo \#define WM_COMPILE_BY \"`whoami`\" >> .ver
@echo \#define WM_COMPILE_HOST \"`hostname`\" >> .ver
@if [ -x /bin/dnsdomainname ]; then \
  echo \#define WM_COMPILE_DOMAIN \"`dnsdomainname`\"; \
elif [ -x /bin/domainname ]; then \
  echo \#define WM_COMPILE_DOMAIN \"`domainname`\"; \
else \
  echo \#define WM_COMPILE_DOMAIN ; \
fi >> .ver
@echo \#define WM_COMPILER \"`$(CC) -v 2>&1 | tail -1`\" >> .ver
@mv -f .ver compile.h
endef

# Compile version.c
define compile-version
$(CC) $(CPPFLAGS) $(CFLAGS) -o version.o -c $(TOPDIR)/sources/RUN/version.c
endef

