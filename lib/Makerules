# Extra rule for version.o
# without it we get problems if compile.h doesn't exist
version.o:
	$(make-version)
	$(compile-version)


.PHONY: depend
# generate dependencies for Makefile
depend: $(SOURCES) $(PCLPROGS_SRC)
# compile.h has to exists - otherwise we get problems
	$(make-version)
	for i in $^ ;do \
		$(CC) $(CPPFLAGS) $(DEPENDFLAGS) $$i ; \
	done > .tmpdepend
	mv .tmpdepend .depend


# clean directory
clean:
	-rm -f .depend .version *.o *.d *.i *.k *.s *.BAK *~ compile.h wm-*

# checking if make depend has been done
.depend:
	@touch .depend
